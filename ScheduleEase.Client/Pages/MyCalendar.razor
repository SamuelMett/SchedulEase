@page "/calendar"
@using ScheduleEase.Client.Components
@using ScheduleEase.Client.Models
@using System.Net.Http.Json
@using Radzen.Blazor
@inject DialogService DialogService
@inject NotificationService NotificationService

<RadzenStack Gap="1rem">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
        <h3>My Google Calendar</h3>
        <RadzenButton 
            Text="Add Event" 
            Icon="add" 
            ButtonStyle="ButtonStyle.Primary" 
            Click="OpenCreateEventDialog" />
    </RadzenStack>

    @if (events == null && string.IsNullOrEmpty(errorMessage))
    {
        <p><em>Loading events...</em></p>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter" AllowClose="false">
            <strong>Error:</strong> @errorMessage
            <br>
            Please <a href="http://127.0.0.1:8000/login" target="_blank">login to your Google Account</a> first, then refresh this page.
        </RadzenAlert>
    }
    else
    {
        <RadzenScheduler @ref="scheduler"
                         Data="@events"
                         TextProperty="Title"
                         StartProperty="Start"
                         EndProperty="End"
                         Style="height: 768px;"
                         SlotRender="@OnSlotRender">
            <RadzenMonthView />
            <RadzenWeekView />
            <RadzenDayView />
        </RadzenScheduler>
    }
</RadzenStack>

@code {
    RadzenScheduler<GoogleCalendarEvent> scheduler;

    void OnSlotRender(SchedulerSlotRenderEventArgs args)
    {
        if (args.View.Text == "Month")
        {
            args.Attributes["style"] = "height: 120px;";
        }
    }

    private async Task OpenCreateEventDialog()
    {
        var result = await DialogService.OpenAsync<CreateEventDialog>(
            "Create New Event",
            null,
            new DialogOptions() 
            { 
                Width = "600px", 
                Height = "auto",
                Resizable = true
            }
        );

        // Optionally reload events after creation
        if (result == true)
        {
            // Reload your events here if needed
            // await LoadEvents();
        }
    }
}