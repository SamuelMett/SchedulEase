@page "/calendar"
@using ScheduleEase.Client.Models
@using System.Net.Http.Json

@inject HttpClient Http
@inject DialogService DialogService
@inject NotificationService NotificationService

<RadzenText TextStyle="TextStyle.H2">My Calendar</RadzenText>
<RadzenText TextStyle="TextStyle.Body1" class="rz-mb-4">
    View, create, and manage your Google Calendar events directly.
</RadzenText>

<RadzenScheduler @ref="scheduler"
                 Data="@events"
                 TItem="EventFromGoogle"
                 TextProperty="Title"
                 StartDateProperty="Start"
                 EndDateProperty="End"
                 SelectedView="SchedulerView.Week"
                 Style="height: 70vh;"
                 LoadData="@OnLoadData"
                 AppointmentRender="OnAppointmentRender"
                 SlotSelect="OnSlotSelect"
                 AppointmentSelect="OnAppointmentSelect"
                 AppointmentMove="OnAppointmentMove"
                 AppointmentResize="OnAppointmentResize">


    <RadzenWeekView />
    <RadzenMonthView />
    <RadzenDayView />
</RadzenScheduler>

@code {
    private RadzenScheduler<EventFromGoogle> scheduler;
    private IList<EventFromGoogle> events = new List<EventFromGoogle>();

    async Task OnLoadData(SchedulerLoadDataEventArgs args)
    {
        try
        {
            var start = args.Start.ToString("yyyy-MM-ddTHH:mm:ss");
            var end = args.End.ToString("yyyy-MM-ddTHH:mm:ss");

            var url = $"/api/calendar/events?start={start}&end={end}";
            var result = await Http.GetFromJsonAsync<List<EventFromGoogle>>(url);

            if (result != null)
            {
                // ✅ FIX 1: Filter out any null items from the API response
                events = result.Where(e => e != null)
                               .Select(e => new EventFromGoogle
                               {
                                   Id = e.Id,
                                   Title = e.Title ?? "(No Title)", // Keep this
                                   Start = e.Start,
                                   End = e.End,
                               }).ToList();
            }
            else
            {
                // If API returns null, ensure events is empty
                events = new List<EventFromGoogle>();
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Could not load events", "Please ensure you are connected to Google.");
            Console.WriteLine($"Error loading events: {ex.Message}");

            // ✅ FIX 2: On ANY error, reset events to a clean state.
            // This prevents Radzen from trying to render with stale/bad data.
            events = new List<EventFromGoogle>();
        }
    }

    // 2. CREATE (POST)
    async Task OnSlotSelect(SchedulerSlotSelectEventArgs args)
    {
        var eventModel = new CalendarEventCreate
        {
            Start = args.Start,
            End = args.End,
            Title = "New Event"
        };

        var dialogResult = await DialogService.OpenAsync<EventDialog>("Create Event",
            new Dictionary<string, object>
            {
                { "EventModel", eventModel },
                { "IsNewEvent", true }
            });

        if (dialogResult is CalendarEventCreate newEvent)
        {
            try
            {
                var response = await Http.PostAsJsonAsync("/api/calendar/events", newEvent);

                if (response.IsSuccessStatusCode)
                {
                    NotificationService.Notify(NotificationSeverity.Success, "Event created");
                    await scheduler.Reload();
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Error", "Could not create event.");
                }
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", $"Could not create event: {ex.Message}");
            }
        }
    }

    // 3. UPDATE (PUT) - Via Dialog
    async Task OnAppointmentSelect(SchedulerAppointmentSelectEventArgs<EventFromGoogle> args)
    {
        var eventModel = new CalendarEventCreate
        {
            Title = args.Data.Title,
            Start = args.Data.Start.ToLocalTime(),
            End = args.Data.End.ToLocalTime(),
            Description = ""
        };

        var dialogResult = await DialogService.OpenAsync<EventDialog>($"Edit Event: {args.Data.Title}",
            new Dictionary<string, object>
            {
                { "EventModel", eventModel },
                { "IsNewEvent", false }
            });

        if (dialogResult is CalendarEventCreate updatedEvent)
        {
            try
            {
                var url = $"/api/calendar/events/{args.Data.Id}";
                var response = await Http.PutAsJsonAsync(url, updatedEvent);

                if (response.IsSuccessStatusCode)
                {
                    NotificationService.Notify(NotificationSeverity.Success, "Event updated");
                    await scheduler.Reload();
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Error", "Could not update event.");
                }
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", $"Could not update event: {ex.Message}");
            }
        }
    }

    // 4. UPDATE (PUT) - Via Drag/Drop or Resize
    private async Task OnAppointmentMove(SchedulerAppointmentMoveEventArgs args)
    {
        var eventData = args.Appointment.Data as EventFromGoogle;
        if (eventData == null) return;
        await UpdateEvent(eventData.Id, args.Appointment.Start, args.Appointment.End);
    }


    private async Task UpdateEvent(string eventId, DateTime start, DateTime end)
    {
        var originalEvent = events.FirstOrDefault(e => e.Id == eventId);
        if (originalEvent == null) return;

        var eventModel = new CalendarEventCreate
        {
            Title = originalEvent.Title,
            Start = start.ToUniversalTime(),
            End = end.ToUniversalTime(),
            Description = ""
        };

        try
        {
            var url = $"/api/calendar/events/{eventId}";
            var response = await Http.PutAsJsonAsync(url, eventModel);

            if (response.IsSuccessStatusCode)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Event updated");
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Update Failed", "Could not save change.");
                await scheduler.Reload();
            }
        }
        catch (Exception)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Update Failed", "Could not save change.");
            await scheduler.Reload();
        }
    }

    // Optional: Style the appointments
    void OnAppointmentRender(SchedulerAppointmentRenderEventArgs<EventFromGoogle> args)
    {
        args.Attributes["style"] = "background-color: var(--rz-info-light);";
    }
}