@page "/assistant"
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms

<header class="ai-topbar">
  <div class="ai-topbar__left">
    <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M13 3l1.29 2.61L17 6.27l-2 2 .47 2.73L13 10.27l-2.47.73L11 8.27l-2-2 2.71-.66L13 3zM5 13l1.29 2.61L9 16.27l-2 2 .47 2.73L5 20.27l-2.47.73L3 18.27l-2-2 2.71-.66L5 13zm12 0l1.29 2.61L21 16.27l-2 2 .47 2.73L17 20.27l-2.47.73L15 18.27l-2-2 2.71-.66L17 13z" fill="currentColor"/>
    </svg>
    <span>SchedulEase Assistant</span>
  </div>
  <div class="ai-topbar__right">
    <span class="ai-dot"></span>
    <span class="ai-muted">Online</span>
  </div>
</header>

<main class="ai-wrap">
  <section class="ai-thread">
    @if (_messages.Count == 0)
    {
      <div class="ai-empty">
        <div class="ai-empty__icon">
          <svg width="48" height="48" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M13 3l1.29 2.61L17 6.27l-2 2 .47 2.73L13 10.27l-2.47.73L11 8.27l-2-2 2.71-.66L13 3zM5 13l1.29 2.61L9 16.27l-2 2 .47 2.73L5 20.27l-2.47.73L3 18.27l-2-2 2.71-.66L5 13zm12 0l1.29 2.61L21 16.27l-2 2 .47 2.73L17 20.27l-2.47.73L15 18.27l-2-2 2.71-.66L17 13z" fill="currentColor"/>
          </svg>
        </div>
        <h2>How can I help you today?</h2>
        <p class="ai-empty__sub">Type a message or click <strong>+</strong> to add a file.</p>
      </div>
    }
    else
    {
      @foreach (var m in _messages)
      {
        bool isUser = m.Role == "user";
        <article class="ai-msg @(isUser ? "is-user" : "is-assistant")">
          <div class="ai-avatar">@(isUser ? "You" : "SE")</div>
          <div class="ai-bubble">
            <div class="ai-meta">
              <span class="ai-who">@(isUser ? "You" : "Assistant")</span>
              <span class="ai-when">@m.At.ToShortTimeString()</span>
            </div>
            @if (m.Typing)
            {
              <div class="ai-typing"><span></span><span></span><span></span></div>
            }
            else
            {
              <div class="ai-text">@m.Text</div>
            }
          </div>
        </article>
      }
    }
  </section>

  <section class="ai-composer">
    <div class="pill">
      <!-- + add icon that triggers hidden file input -->
      <label class="pill__plus" for="uploader" title="Add file">
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 5v14m-7-7h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </label>

      <InputFile id="uploader"
                 class="visually-hidden"
                 OnChange="HandleFileSelected"
                 accept=".pdf,.doc,.docx,.txt" />

      <!-- text input -->
      <input class="pill__input"
             type="text"
             placeholder="Ask anything"
             @bind="_input"
             @bind:event="oninput"
             @onkeydown="HandleKeyDown" />

      <!-- send -->
      <button class="pill__send"
              @onclick="OnSend"
              disabled="@string.IsNullOrWhiteSpace(_input)"
              title="Send">
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 12l18-9-6 9 6 9-18-9z" fill="currentColor"/>
        </svg>
      </button>
    </div>

    <div class="ai-hint">Press <kbd>Enter</kbd> to send • Click <span class="hint-plus">+</span> to add file</div>
  </section>
</main>

@code {
  private sealed record ChatMessage(string Role, string Text, DateTime At, bool Typing = false);
  private readonly List<ChatMessage> _messages = new();
  private string _input = string.Empty;

  protected override void OnInitialized()
  {
    _messages.Add(new ChatMessage(
      "assistant",
      "Hi! Ask me about your schedule — or click + to add a syllabus file.",
      DateTime.Now));
  }

  private async Task HandleKeyDown(KeyboardEventArgs e)
  {
    if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_input))
      await OnSend();
  }

  private async Task OnSend()
  {
    var text = _input?.Trim();
    if (string.IsNullOrWhiteSpace(text)) return;

    _messages.Add(new ChatMessage("user", text, DateTime.Now));
    _input = string.Empty;

    var typing = new ChatMessage("assistant", "", DateTime.Now, Typing: true);
    _messages.Add(typing);

    await Task.Delay(400);
    var reply = BuildPlaceholderReply(text);

    var idx = _messages.IndexOf(typing);
    if (idx >= 0) _messages[idx] = new ChatMessage("assistant", reply, DateTime.Now);

    StateHasChanged();
  }

  private async Task HandleFileSelected(InputFileChangeEventArgs e)
  {
    var file = e.File;
    if (file is null) return;

    _messages.Add(new ChatMessage("user", $"📎 {file.Name}", DateTime.Now));
    _messages.Add(new ChatMessage("assistant", $"Nice! I’ll process **{file.Name}** when upload is enabled.", DateTime.Now));
    await InvokeAsync(StateHasChanged);
  }

  private string BuildPlaceholderReply(string prompt)
  {
    if (prompt.Contains("due", StringComparison.OrdinalIgnoreCase))
      return "Once you upload a syllabus, I’ll list upcoming deadlines.";
    if (prompt.Contains("syllabus", StringComparison.OrdinalIgnoreCase))
      return "Upload a PDF syllabus and I’ll extract dates and tasks.";
    if (prompt.Contains("canvas", StringComparison.OrdinalIgnoreCase))
      return "After Canvas is connected, ask “What’s due this week?”";
    return $"You said: {prompt}";
  }
}
