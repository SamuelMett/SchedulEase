@page "/assistant"
@using System.Text.Json
@using System.Text.Json.Serialization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms

@inject HttpClient Http

<header class="ai-topbar">
  <div class="ai-topbar__left">
    <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M13 3l1.29 2.61L17 6.27l-2 2 .47 2.73L13 10.27l-2.47.73L11 8.27l-2-2 2.71-.66L13 3zM5 13l1.29 2.61L9 16.27l-2 2 .47 2.73L5 20.27l-2.47.73L3 18.27l-2-2 2.71-.66L5 13zm12 0l1.29 2.61L21 16.27l-2 2 .47 2.73L17 20.27l-2.47.73L15 18.27l-2-2 2.71-.66L17 13z" fill="currentColor"/>
    </svg>
    <span>SchedulEase Assistant</span>
  </div>
  <div class="ai-topbar__right">
    <span class="ai-dot"></span>
    <span class="ai-muted">Online</span>
  </div>
</header>

<main class="ai-wrap">
  <section class="ai-thread">
    @if (_messages.Count == 0)
    {
      <div class="ai-empty">
        <div class="ai-empty__icon">
          <svg width="48" height="48" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M13 3l1.29 2.61L17 6.27l-2 2 .47 2.73L13 10.27l-2.47.73L11 8.27l-2-2 2.71-.66L13 3zM5 13l1.29 2.61L9 16.27l-2 2 .47 2.73L5 20.27l-2.47.73L3 18.27l-2-2 2.71-.66L5 13zm12 0l1.29 2.61L21 16.27l-2 2 .47 2.73L17 20.27l-2.47.73L15 18.27l-2-2 2.71-.66L17 13z" fill="currentColor"/>
          </svg>
        </div>
        <h2>How can I help you today?</h2>
        <p class="ai-empty__sub">Type a message or click <strong>+</strong> to add a file.</p>
      </div>
    }
    else
    {
      @foreach (var m in _messages)
      {
        bool isUser = m.Role == "user";
        <article class="ai-msg @(isUser ? "is-user" : "is-assistant")">
          <div class="ai-avatar">@(isUser ? "You" : "SE")</div>
          <div class="ai-bubble">
            <div class="ai-meta">
              <span class="ai-who">@(isUser ? "You" : "Assistant")</span>
              <span class="ai-when">@m.At.ToShortTimeString()</span>
            </div>
            @if (m.Typing)
            {
              <div class="ai-typing"><span></span><span></span><span></span></div>
            }
            else
            {
              <div class="ai-text">@m.Text</div>
            }
          </div>
        </article>
      }
    }
  </section>

  <section class="ai-composer">
    <div class="pill">
      <!-- + add icon triggers hidden file input -->
      <label class="pill__plus" for="uploader" title="Add file">
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 5v14m-7-7h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </label>

      <InputFile id="uploader"
                 class="visually-hidden"
                 OnChange="HandleFileSelected"
                 accept=".pdf,.doc,.docx,.txt" />

      <!-- text input -->
      <input class="pill__input"
             type="text"
             placeholder="Ask anything"
             @bind="_input"
             @bind:event="oninput"
             @onkeydown="HandleKeyDown" />

      <!-- send -->
      <button class="pill__send"
              @onclick="OnSend"
              disabled="@string.IsNullOrWhiteSpace(_input)"
              title="Send">
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 12l18-9-6 9 6 9-18-9z" fill="currentColor"/>
        </svg>
      </button>
    </div>

    <div class="ai-hint">Press <kbd>Enter</kbd> to send • Click <span class="hint-plus">+</span> to add file</div>
  </section>
</main>

@code {
  // ---------- UI model ----------
  private sealed record ChatMessage(string Role, string Text, DateTime At, bool Typing = false);
  private readonly List<ChatMessage> _messages = new();
  private string _input = string.Empty;

  // Use one session id per browser tab
  private readonly string _sessionId = Guid.NewGuid().ToString("N");

  // ---------- API models (match backend) ----------
  private sealed class ChatSendRequest
  {
      [JsonPropertyName("session_id")] public string SessionId { get; set; } = default!;
      [JsonPropertyName("message")]    public string Message   { get; set; } = default!;
      // We’ll omit keywords unless explicitly needed
  }

  private sealed class ChatResponse
  {
      [JsonPropertyName("type")]    public string Type { get; set; } = "";
      [JsonPropertyName("message")] public string Message { get; set; } = "";
      [JsonPropertyName("data")]    public JsonElement? Data { get; set; }
  }

  protected override void OnInitialized()
  {
    _messages.Add(new ChatMessage(
      "assistant",
      "Hi! Ask me about your schedule — or click + to add a syllabus file.",
      DateTime.Now));
  }

  // Enter to send (Shift+Enter = newline if you ever swap to <textarea>)
  private async Task HandleKeyDown(KeyboardEventArgs e)
  {
    if (e.Key == "Enter" && !e.ShiftKey && !string.IsNullOrWhiteSpace(_input))
    {
      await OnSend();
    }
  }

  private async Task OnSend()
  {
    var text = _input?.Trim();
    if (string.IsNullOrWhiteSpace(text)) return;

    // Add user's bubble
    _messages.Add(new ChatMessage("user", text, DateTime.Now));
    _input = string.Empty;

    // Add typing bubble
    var typing = new ChatMessage("assistant", "", DateTime.Now, Typing: true);
    _messages.Add(typing);
    StateHasChanged();

    try
    {
      var req = new ChatSendRequest { SessionId = _sessionId, Message = text };
      var httpResp = await Http.PostAsJsonAsync("/api/chat/send", req);
      httpResp.EnsureSuccessStatusCode();

      var payload = await httpResp.Content.ReadFromJsonAsync<ChatResponse>();
      var reply = payload?.Message ?? "…";

      // replace typing bubble
      var idx = _messages.IndexOf(typing);
      if (idx >= 0) _messages[idx] = new ChatMessage("assistant", reply, DateTime.Now);
    }
    catch (Exception ex)
    {
      var idx = _messages.IndexOf(typing);
      if (idx >= 0) _messages[idx] = new ChatMessage("assistant",
        $"Sorry, I couldn’t reach the server. {ex.Message}", DateTime.Now);
    }

    StateHasChanged();
  }

  private async Task HandleFileSelected(InputFileChangeEventArgs e)
  {
    var file = e.File;
    if (file is null) return;

    // Show file message
    _messages.Add(new ChatMessage("user", $"📎 {file.Name}", DateTime.Now));

    // Assistant typing
    var typing = new ChatMessage("assistant", "", DateTime.Now, Typing: true);
    _messages.Add(typing);
    StateHasChanged();

    try
    {
      // Build multipart form
      using var content = new MultipartFormDataContent();
      // IMPORTANT: provide the session_id form field name expected by backend
      content.Add(new StringContent(_sessionId), "session_id");

      // Limit stream if you want (e.g., 20 MB)
      const long max = 20 * 1024 * 1024;
      using var stream = file.OpenReadStream(max);
      var fileContent = new StreamContent(stream);
      fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType ?? "application/octet-stream");
      content.Add(fileContent, "file", file.Name);

      var httpResp = await Http.PostAsync("/api/chat/upload", content);
      httpResp.EnsureSuccessStatusCode();

      // Friendly confirmation
      var okText = $"Syllabus attached. You can now ask “what’s due” or request a study plan.";
      var idx = _messages.IndexOf(typing);
      if (idx >= 0) _messages[idx] = new ChatMessage("assistant", okText, DateTime.Now);
    }
    catch (Exception ex)
    {
      var idx = _messages.IndexOf(typing);
      if (idx >= 0) _messages[idx] = new ChatMessage("assistant",
        $"Upload failed: {ex.Message}", DateTime.Now);
    }

    StateHasChanged();
  }
}
