@page "/login"
@using SchedulEase.Services
@using SchedulEase.Models
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="login-page-wrapper">
    <RadzenCard Class="login-card">
        
        <!-- Header -->
        <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center" Gap="0.5rem" Class="rz-mb-4">
            <RadzenText Text="SchedulEase" TextStyle="TextStyle.H3" Style="color: #667eea; font-weight: 700;" />
            <RadzenText Text="Simplify your scheduling with AI" TextStyle="TextStyle.Body1" Style="color: #6b7280;" />
        </RadzenStack>

        <!-- Error Message -->
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter" Class="rz-mb-4">
                @errorMessage
            </RadzenAlert>
        }

        <!-- Success Message -->
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" Variant="Variant.Flat" Shade="Shade.Lighter" Class="rz-mb-4">
                @successMessage
            </RadzenAlert>
        }

        <!-- Sign In Form -->
        <RadzenStack Gap="1.25rem">
            <RadzenText Text="Sign In" TextStyle="TextStyle.H5" Style="text-align: center;" />

            <RadzenFormField Text="Email" Variant="Variant.Outlined">
                <RadzenTextBox @bind-Value="email" Placeholder="Enter your email" Style="width: 100%;" />
            </RadzenFormField>

            <RadzenFormField Text="Password" Variant="Variant.Outlined">
                <RadzenPassword @bind-Value="password" Placeholder="Enter your password" Style="width: 100%;" />
            </RadzenFormField>

            <RadzenButton Text="Sign In" ButtonStyle="ButtonStyle.Primary" Style="width: 100%;" Click="HandleSignIn" />

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="0.5rem">
                <RadzenText Text="Don't have an account?" TextStyle="TextStyle.Body2" Style="color: #6b7280;" />
                <RadzenLink Text="Sign Up" Path="/signup" Style="font-weight: 600; cursor: pointer;" />
            </RadzenStack>
        </RadzenStack>

        <!-- Demo Accounts Section -->
        <RadzenStack Gap="1rem" Class="rz-mt-5" Style="border-top: 1px solid #e5e7eb; padding-top: 1.5rem;">
            <RadzenText Text="Demo Accounts" TextStyle="TextStyle.Subtitle1" Style="text-align: center; color: #374151;" />
            
            @foreach (var user in AuthService.GetSeededUsers())
            {
                <RadzenCard Variant="Variant.Outlined" Style="padding: 0.75rem;">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                        <RadzenStack Gap="0.25rem">
                            <RadzenText Text="@user.FullName" TextStyle="TextStyle.Subtitle2" Style="font-weight: 600;" />
                            <RadzenText Text="@user.Email" TextStyle="TextStyle.Caption" Style="color: #6b7280;" />
                        </RadzenStack>
                        <RadzenButton Text="Quick Login" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light" Click="() => QuickLogin(user.Email, user.Password)" />
                    </RadzenStack>
                </RadzenCard>
            }
        </RadzenStack>

    </RadzenCard>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private void HandleSignIn()
    {
        ClearMessages();

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Please enter both email and password.";
            return;
        }

        if (AuthService.SignIn(email, password))
        {
            successMessage = "Login successful! Redirecting...";
            Navigation.NavigateTo("/home");
        }
        else
        {
            errorMessage = "Invalid email or password.";
        }
    }

    private void QuickLogin(string userEmail, string userPassword)
    {
        email = userEmail;
        password = userPassword;
        HandleSignIn();
    }

    private void ClearMessages()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }
}
