@using ScheduleEase.Client.Models
@inject DialogService DialogService

<RadzenTemplateForm TItem="CalendarEventCreate" Data="@EventModel" Submit="OnSubmit">
    <RadzenStack Gap="1rem">

        <RadzenFieldset Text="Event Details">
            <RadzenStack Gap="1.5rem">

                <RadzenStack Gap="0.5rem">
                    <RadzenLabel Text="Title" Component="Title" />
                    <RadzenTextBox @bind-Value="EventModel.Title" Id="Title" Name="Title" />
                    <RadzenRequiredValidator Component="Title" Text="Title is required" Popup="true" />
                </RadzenStack>

                <RadzenStack Gap="0.5rem">
                    <RadzenLabel Text="Start" Component="Start" />
                    <RadzenDatePicker @bind-Value="EventModel.Start" Id="Start" Name="Start" ShowTime="true" />
                </RadzenStack>

                <RadzenStack Gap="0.5rem">
                    <RadzenLabel Text="End" Component="End" />
                    <RadzenDatePicker @bind-Value="EventModel.End" Id="End" Name="End" ShowTime="true" />
                </RadzenStack>

                <RadzenStack Gap="0.5rem">
                    <RadzenLabel Text="Description" Component="Description" />
                    <RadzenTextArea @bind-Value="EventModel.Description" Id="Description" Name="Description" />
                </RadzenStack>

            </RadzenStack>
        </RadzenFieldset>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem">
            <RadzenButton ButtonType="ButtonType.Submit" Text="Save" Icon="save" ButtonStyle="ButtonStyle.Primary" />
            <RadzenButton ButtonType="ButtonType.Button" Text="Cancel" Icon="cancel" ButtonStyle="ButtonStyle.Light" Click="OnCancel" />
        </RadzenStack>

    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter]
    public CalendarEventCreate EventModel { get; set; } = new();

    [Parameter]
    public bool IsNewEvent { get; set; } = true;

    private void OnSubmit(CalendarEventCreate args)
    {
        // This closes the dialog and passes the
        // completed model back to the Calendar.razor page
        DialogService.Close(args);
    }

    private void OnCancel()
    {
        DialogService.Close(null);
    }
}