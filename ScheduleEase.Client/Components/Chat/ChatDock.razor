@using Radzen
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Forms

@code {
  bool isOpen = false;

  record ChatMessage(string Role, string Text, DateTime At);
  List<ChatMessage> msgs = new()
  {
    new("bot","Hey! I’m your SchedulEase assistant. Ask me about assignments, exams, or to build a study plan.", DateTime.Now)
  };

  string input = "";

  string Reply(string t){
    t = (t ?? "").ToLowerInvariant();
    if (t.Contains("schedule") || t.Contains("plan"))
      return "Here’s a sample plan:\n• 8:00 — CS\n• 11:00 — Project\n• 2:00 — Lunch\n• 3:00 — Study";
    if (t.Contains("assignment") || t.Contains("homework"))
      return "You have 3 items:\n• AI Lab 4 (Fri)\n• UX Report (Sun)\n• DBMS Project (Tue)";
    if (t.Contains("exam") || t.Contains("test"))
      return "Next exam: CMPS 383 — Tue 9:00 AM.";
    if (t.Contains("hello") || t.Contains("hi"))
      return "Hey! How can I help today?";
    if (t.Contains("thank"))
      return "No problem!";
    return "Try asking about your schedule, exams, or assignments.";
  }

  async Task SendAsync(){
    var val = (input ?? "").Trim();
    if (string.IsNullOrEmpty(val)) return;

    msgs.Add(new("user", val, DateTime.Now));
    input = "";

    // TODO: replace with your real AI call
    await Task.Delay(250);
    msgs.Add(new("bot", Reply(val), DateTime.Now));
    await InvokeAsync(StateHasChanged);
  }

  async Task OnKeyDown(KeyboardEventArgs e){
    if (e.Key == "Enter" && !e.ShiftKey){
      input = (input ?? "").TrimEnd('\r','\n');
      await SendAsync();
    }
  }

  async Task OnFiles(InputFileChangeEventArgs e){
    var list = e.GetMultipleFiles().Select(f => $"{f.Name} ({Bytes(f.Size)})");
    msgs.Add(new("bot", $"Files selected:\n{string.Join("\n", list)}\n(Handle upload in backend.)", DateTime.Now));
    await InvokeAsync(StateHasChanged);
  }

  static string Bytes(long n){
    string[] u = { "B","KB","MB","GB","TB" }; int i=0; double d=n;
    while (d>=1024 && i<u.Length-1){ d/=1024; i++; }
    return $"{(d<10&&i>0?d.ToString("0.0"):Math.Round(d))} {u[i]}";
  }
}

<style>
  :root { --se-blue:#2563eb; --se-blue-dark:#1d4ed8; --se-border:#e2e8f0; --se-muted:#64748b; }
  :root { --rz-primary:#2563eb; --rz-on-primary:#fff } /* Radzen primary = blue */

  /* Floating bubble */
  .se-chat-fab { position: fixed; right: 24px; bottom: 24px; z-index: 2147483647; }
  .se-chat-fab button{
    border:none; border-radius:9999px; padding:12px 18px;
    background:linear-gradient(180deg,var(--se-blue),var(--se-blue-dark));
    color:#fff; font-weight:600; box-shadow:0 10px 28px rgba(37,99,235,.35);
    cursor:pointer; transition:.18s;
  }
  .se-chat-fab button:hover{ transform:translateY(-2px); filter:brightness(1.05); }

  /* Docked panel */
  .se-chat-panel{
    position: fixed; right: 24px; bottom: 24px; z-index: 2147483647;
    width: 420px; max-width: 95vw; height: 560px;
    background:#fff; border:1px solid var(--se-border); border-radius:14px;
    box-shadow:0 12px 40px rgba(0,0,0,.18);
    display:flex; flex-direction:column; overflow:hidden;
    animation: se-slide-up .16s ease-out;
  }
  @@keyframes se-slide-up { from { transform: translateY(8px); opacity:.0 } to { transform:none; opacity:1 } }

  .se-chat-header{
    display:flex; align-items:center; justify-content:space-between;
    padding:12px 14px; color:#fff;
    background:linear-gradient(90deg,#1e3a8a,var(--se-blue));
    border-bottom:1px solid rgba(255,255,255,.15);
  }
  .se-brand{ display:flex; gap:10px; align-items:center }
  .se-avatar{ width:34px; height:34px; border-radius:9999px; background:#fff; color:var(--se-blue);
              display:grid; place-items:center; font-weight:700 }
  .se-title .name{ font-weight:600; font-size:15px }
  .se-title .sub{ font-size:12px; opacity:.9; color:#e8eefc }
  .se-x{ border:none; background:transparent; color:#fff; font-size:18px; cursor:pointer; padding:4px 8px; border-radius:8px }
  .se-x:hover{ background:rgba(255,255,255,.15) }

  /* Messages */
  .se-msgs{ flex:1 1 auto; min-height:0; overflow:auto; padding:14px; background:#f1f5f9 }
  .se-msgs .row{ display:flex; gap:10px; margin:10px 0; align-items:flex-start; } 
  .row.user{ justify-content:flex-end }

  /* SE chip */
  .chip {
  width: 34px;
  height: 34px;
  flex: 0 0 34px;
  border-radius: 50%;
  background: linear-gradient(180deg, #3b82f6, #1d4ed8);
  box-shadow: 0 3px 8px rgba(37, 99, 235, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4px;
  margin-right: 8px;
  transform: translateY(1px); 
}

.chip > span {
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.3px;
  line-height: 1;
}


  /* Bubbles */
  .bubble{
    max-width:82%; padding:12px 14px; border-radius:16px;
    box-shadow:0 4px 10px rgba(0,0,0,.06);
    font-size:.97rem; line-height:1.55;
  }
  .bot{ background:#fff; border:1px solid var(--se-border); border-bottom-left-radius:6px }
  .userb{ background:var(--se-blue); color:#fff; border-bottom-right-radius:6px }
  .t{ margin-top:5px; font-size:.72rem; color:var(--se-muted) }
  .t.user{ color:#e0eaff; text-align:right }

  /* Composer */
  .se-composer{ border-top:1px solid var(--se-border); background:#fff; padding:12px }
  .se-composer .row{ display:flex; align-items:center; gap:10px }
  .rz-textarea{ flex:1 1 auto; min-height:44px; max-height:120px; border-radius:10px }
  .rz-button{ border-radius:12px; height:44px; min-width:44px }
</style>


@if (!isOpen)
{
  <!-- Floating bubble -->
  <div class="se-chat-fab">
    <button @onclick="() => isOpen = true">Chat</button>
  </div>
}
else
{
  <!-- Docked panel -->
  <section class="se-chat-panel" role="dialog" aria-label="SchedulEase chat">
    <header class="se-chat-header">
      <div class="se-brand">
        <div class="se-avatar">S</div>
        <div class="se-title">
          <div class="name">SchedulEase</div>
          <div class="sub">AI assistant</div>
        </div>
      </div>
      <button class="se-x" title="Close" @onclick="() => isOpen = false">✕</button>
    </header>

    <div class="se-msgs" id="se-msgs">
      @foreach (var m in msgs)
      {
        var u = m.Role == "user";
        <div class="row @(u ? "user" : "")">
          @if (!u) { <div class="chip"><span>SE</span></div> }
          <div>
            <div class="bubble @(u ? "userb" : "bot")">@m.Text</div>
            <div class="t @(u ? "user" : "")">@m.At.ToShortTimeString()</div>
          </div>
        </div>
      }
    </div>

    <footer class="se-composer">
  <div class="row">
    <RadzenTextArea @bind-Value="input"
                    Rows="2"
                    Placeholder="Type a message…"
                    @onkeydown="OnKeyDown"
                    Style="flex:1" />

    <RadzenButton Icon="send"
                  ButtonStyle="ButtonStyle.Primary"
                  Click="@SendAsync"
                  Style="border-radius:12px; height:44px; min-width:44px;" />
  </div>

  <div style="font-size:11px;color:#94a3b8;margin:6px 4px 0;text-align:center">
    Enter to send • Shift+Enter for newline
  </div>
</footer>

  </section>
}
