@inherits LayoutComponentBase
@using SchedulEase.Services
@inject NavigationManager NavigationManager
@inject AuthService AuthService

@if (!AuthService.IsAuthenticated && !NavigationManager.Uri.Contains("/login") && !NavigationManager.Uri.Contains("/signup"))
{
    NavigationManager.NavigateTo("/login");
}

<RadzenLayout>
    @if (AuthService.IsAuthenticated)
    {
        <RadzenHeader Style="height: 80px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Style="padding: 0 2rem; height: 100%;">

                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="3rem">
                    <!-- User Greeting -->
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem">
                        <RadzenIcon Icon="person" Style="color: #667eea; font-size: 28px;" />
                        <RadzenText Text="@($"Hello, {AuthService.CurrentUser?.FullName}")" TextStyle="TextStyle.H6" Style="font-weight: 600; color: #111827; font-size: 1.1rem;" />
                    </RadzenStack>

                    <RadzenLink Text="Home" Path="/home" Style="font-size: 1.1rem; font-weight: 500; color: #374151; text-decoration: none; transition: color 0.2s;" />
                    <RadzenLink Text="Calendar" Path="/calendar" Style="font-size: 1.1rem; font-weight: 500; color: #374151; text-decoration: none; transition: color 0.2s;" />
                    <RadzenLink Text="Import" Path="/import" Style="font-size: 1.1rem; font-weight: 500; color: #374151; text-decoration: none; transition: color 0.2s;" />
                </RadzenStack>

                <!-- Sign Out Button -->
                <RadzenButton Text="Sign Out" Icon="logout" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Size="ButtonSize.Medium" Click="HandleSignOut" />
            </RadzenStack>
        </RadzenHeader>
    }

    <RadzenBody>
        <div class="main-content">
            @Body
        </div>
    </RadzenBody>

</RadzenLayout>

@code {
    private void HandleSignOut()
    {
        AuthService.SignOut();
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }
}