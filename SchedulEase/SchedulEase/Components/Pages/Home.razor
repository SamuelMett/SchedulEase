@page "/"

<div class="bg-gray-900 text-white min-h-screen font-sans">
    <!-- Header -->
    <header class="border-b border-gray-700 bg-gray-800 sticky top-0 z-50">
        <div class="container mx-auto px-4 py-4 flex justify-between items-center">
            <!-- Logo -->
            <div class="flex items-center gap-3 cursor-pointer" @onclick='() => currentView = "Home"'>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-indigo-400"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                <h1 class="text-xl font-bold">
                    Schedul<span class="text-red-500">Ease</span>
                </h1>
            </div>

            <!-- Navigation Links -->
            <nav class="hidden md:flex gap-4 text-sm">
                <a @onclick='() => currentView = "Home"' class="cursor-pointer hover:text-indigo-400 transition-colors">Home</a>
                <a @onclick='() => currentView = "Canvas"' class="cursor-pointer hover:text-indigo-400 transition-colors">Canvas</a>
                <a @onclick='() => currentView = "Upload"' class="cursor-pointer hover:text-indigo-400 transition-colors">Upload</a>
                <a @onclick='() => currentView = "Calendar"' class="cursor-pointer hover:text-indigo-400 transition-colors">Calendar</a>
                <a @onclick='() => currentView = "Chat"' class="cursor-pointer hover:text-indigo-400 transition-colors">AI Chat</a>
                <a @onclick='() => currentView = "Settings"' class="cursor-pointer hover:text-indigo-400 transition-colors">Settings</a>
            </nav>
        </div>
    </header>

    <!-- Main Content: View changes based on navigation -->
    <main class="container mx-auto px-4 py-10">
        @switch (currentView)
        {
            case "Home":
                @HomeView
                break;
            case "Upload":
                @UploadView
                break;
            case "Calendar":
                @CalendarView
                break;
            case "Chat":
                @AIChatView
                break;
            case "Settings":
                @SettingsView
                break;
            case "Canvas":
                @CanvasView
                break;
        }
    </main>
</div>


@code {
    private string currentView = "Home";

    // ----- C# Classes to hold data for our UI -----
    public class FileUploadModel
    {
        public string Name { get; set; } = "";
        public long Size { get; set; }
    }
    private FileUploadModel? uploadedFile;


    public class CalendarEvent
    {
        public string Title { get; set; } = "";
        public DateTime Date { get; set; }
        public double Confidence { get; set; }
    }
    // Mock data based on your figma
    private List<CalendarEvent> extractedEvents = new List<CalendarEvent>
    {
        new CalendarEvent { Title = "Intro Essay Draft", Date = new DateTime(2025, 9, 3), Confidence = 0.95 },
        new CalendarEvent { Title = "Reading Quiz Ch 1-2", Date = new DateTime(2025, 9, 5), Confidence = 0.88 },
        new CalendarEvent { Title = "Math Problem Set 1", Date = new DateTime(2025, 9, 8), Confidence = 0.92 },
    };

    public class ChatMessage
    {
        public string Text { get; set; } = "";
        public bool IsUser { get; set; }
    }
    private List<ChatMessage> chatMessages = new List<ChatMessage>
    {
        new ChatMessage { Text = "Hi! How can I help you study or organize your schedule?", IsUser = false }
    };

    // ----- UI Blocks (RenderFragments) for each view -----

    // Home Page View
    private RenderFragment HomeView =>@<div class="space-y-16">
        <!-- Hero Section -->
        <section class="text-center py-10">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-indigo-900 text-indigo-300">
                🚀 AI-Powered Academic Planning
            </span>
            <h1 class="text-4xl lg:text-5xl font-bold leading-tight mt-4">
                Transform Your
                <span class="text-blue-400"> Academic Life</span> with
                <span class="text-red-500"> SchedulEase</span>
            </h1>
            <p class="text-lg text-gray-400 leading-relaxed max-w-2xl mx-auto mt-6">
                Never miss another deadline. Our AI automatically extracts assignments from syllabi
                and Canvas, creating a personalized study calendar that adapts to your schedule.
            </p>
            <div class="mt-8">
                <button @onclick='() => currentView = "Upload"' class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 rounded-lg font-semibold flex items-center justify-center gap-2 mx-auto">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="12" y1="18" x2="12" y2="12"></line><line x1="9" y1="15" x2="15" y2="15"></line></svg>
                    Upload Syllabus
                </button>
            </div>
        </section>

        <!-- Features Section -->
        <section class="max-w-5xl mx-auto">
            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
                <div class="p-6 text-center bg-gray-800 rounded-lg">
                    <h3 class="font-semibold mb-2">Smart Syllabus Parsing</h3>
                    <p class="text-sm text-gray-400">
                        AI automatically extracts assignments, exams, and deadlines from any syllabus format.
                    </p>
                </div>
                <div class="p-6 text-center bg-gray-800 rounded-lg">
                    <h3 class="font-semibold mb-2">Canvas Integration</h3>
                    <p class="text-sm text-gray-400">
                        Sync your Canvas courses to automatically import all your assignments and events.
                    </p>
                </div>
                <div class="p-6 text-center bg-gray-800 rounded-lg">
                    <h3 class="font-semibold mb-2">Google Calendar Sync</h3>
                    <p class="text-sm text-gray-400">
                        Export your academic schedule directly to your Google Calendar with one click.
                    </p>
                </div>
                <div class="p-6 text-center bg-gray-800 rounded-lg">
                    <h3 class="font-semibold mb-2">AI Study Assistant</h3>
                    <p class="text-sm text-gray-400">
                        Ask our AI for study tips, schedule adjustments, or help understanding topics.
                    </p>
                </div>
            </div>
        </section>
    </div>;

    // Upload Page View
    private RenderFragment UploadView =>@<div class="max-w-4xl mx-auto space-y-6">
    <div class="text-center">
        <h2 class="text-3xl font-bold">Upload Your Syllabus</h2>
        <p class="text-gray-400">Let our AI extract your schedule in seconds.</p>
    </div>
    <div class="bg-gray-800 border-2 border-dashed border-gray-600 rounded-lg p-12 text-center">
        <h3 class="text-xl font-semibold mb-2">Drag & Drop or Select File</h3>
        <p class="text-gray-400 mb-4">Supports PDF, DOCX, and other text formats</p>
        <input type="file" class="relative block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-indigo-600 file:text-white hover:file:bg-indigo-700" />
    </div>

    <!-- This is a placeholder for the results view. In a real app, you would show this section conditionally -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 pt-6">
        <div class="bg-gray-800 p-4 rounded-lg border border-gray-700 space-y-4">
            <h3 class="font-semibold">Processing Status</h3>
            <p class="text-sm text-green-400">✅ Success! Found 3 events.</p>
            <button class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-4 rounded-lg">Add to Calendar</button>
        </div>
        <div class="bg-gray-800 p-4 rounded-lg border border-gray-700">
            <h3 class="font-semibold mb-3">AI Extracted Events</h3>
            <ul class="space-y-2">
                @foreach (var ev in extractedEvents)
                                {
                <li class="text-sm p-2 bg-gray-700 rounded-lg">
                    <div class="flex justify-between">
                        <span>@ev.Date.ToString("MMM dd"): @ev.Title</span>
                        <span class="text-green-400">@((ev.Confidence * 100).ToString("F0"))%</span>
                    </div>
                </li>
                                }
            </ul>
        </div>
    </div>
</div>;

    // Calendar Page View
    private RenderFragment CalendarView =>@<div>
    <header class="mb-8 text-center">
        <h2 class="text-3xl font-bold text-white">September 2025</h2>
    </header>
    <div class="grid grid-cols-7 gap-px bg-gray-700 rounded-lg border border-gray-700">
        @foreach (var day in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
                {
            <div class="text-center font-semibold text-gray-300 py-2 bg-gray-800">@day</div>
        }

        @for (int i = 0; i < 35; i++)
        {
            var dayNumber = i - 0; // Static offset for Sept 1st 2025 being a Monday
            var currentDate = new DateTime(2025, 9, 1).AddDays(dayNumber - 1);
            <div class="h-32 bg-gray-800 p-2 relative flex flex-col overflow-hidden">
                @if (dayNumber > 0 && dayNumber <= 30)
                {
                    <span class="text-sm font-semibold text-gray-400">@dayNumber</span>
                    <div class="flex-grow mt-1 space-y-1 overflow-y-auto">
                        @foreach (var ev in extractedEvents.Where(e => e.Date == currentDate))
                        {
                            <div class="bg-indigo-500 text-white text-xs rounded p-1 truncate">@ev.Title</div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>;

// AI Chat View
private RenderFragment AIChatView =>@<div class="bg-gray-800 rounded-lg p-4 flex flex-col max-w-2xl mx-auto" style="height: 70vh;">
    <h3 class="font-semibold mb-2 text-indigo-400 text-center">Study Bot</h3>
    <div class="flex-grow overflow-y-auto mb-2 space-y-4 p-2">
        @foreach (var message in chatMessages)
        {
            <div class="flex @(message.IsUser ? "justify-end" : "justify-start")">
                <div class="text-sm p-3 rounded-lg max-w-xs @(message.IsUser ? "bg-indigo-600" : "bg-gray-700")">
                    @message.Text
                </div>
            </div>
        }
    </div>
    <div class="flex mt-2">
        <input type="text" placeholder="Ask for help..." class="bg-gray-900 text-white w-full rounded-l-md p-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        <button class="bg-indigo-600 text-white px-4 rounded-r-md hover:bg-indigo-700">Send</button>
    </div>
</div>;

// Settings View
private RenderFragment SettingsView =>@<div class="max-w-2xl mx-auto">
    <h2 class="text-3xl font-semibold mb-4">Settings</h2>
    <div class="bg-gray-800 p-6 rounded-lg space-y-4">
        <div>
            <h3 class="font-semibold">Account</h3>
            <p class="text-sm text-gray-400">Manage your account preferences.</p>
        </div>
        <hr class="border-gray-700" />
        <div>
            <h3 class="font-semibold">Connections</h3>
            <p class="text-sm text-gray-400">Connect to Google Calendar and Canvas.</p>
        </div>
    </div>
</div>;

// Canvas View
private RenderFragment CanvasView =>@<div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl font-semibold mb-4">Connect to Canvas</h2>
    <div class="bg-gray-800 p-8 rounded-lg">
        <p class="text-gray-400 mb-6">Import assignments and deadlines directly from Canvas LMS to build your master schedule.</p>
        <button class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg">Connect Canvas</button>
    </div>
</div>;
}
