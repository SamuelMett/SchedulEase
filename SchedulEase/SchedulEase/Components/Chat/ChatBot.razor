@* Chatbot.razor — minimal, framework-independent chat dock *@

<style>
/* ==== variables ==== */
:root{
  --se-purple:#a800b7;
  --se-purple-600:#870093;
  --se-text:#111827;
  --se-muted:#6b7280;
  --se-border:#e5e7eb;
}

/* ==== open button (fab) ==== */
#chatdock-open{
  position:fixed; bottom:24px; right:24px; z-index:9999;
  border:none; border-radius:9999px; padding:12px 16px;
  background:linear-gradient(180deg,var(--se-purple),var(--se-purple-600));
  color:#fff; font-weight:600; cursor:pointer;
  box-shadow:0 10px 30px rgba(168,0,183,.35);
}
#chatdock-open:hover{ filter:brightness(1.05); }
#chatdock-open:active{ filter:brightness(.95); }

/* ==== panel (no blur) ==== */
#chatdock-panel{
  position:fixed; bottom:24px; right:24px; z-index:10000;
  width:380px; height:560px; display:none;
  background:#fff; color:var(--se-text);
  border:1px solid var(--se-border); border-radius:16px;
  box-shadow:0 12px 32px rgba(0,0,0,.18);
  overflow:hidden;
}

/* header */
#chatdock-header{
  display:flex; align-items:center; justify-content:space-between;
  padding:12px 16px; background:#111827; color:#fff;
}
#chatdock-brand{ display:flex; align-items:center; gap:10px; }
#chatdock-avatar{ width:32px; height:32px; border-radius:9999px; background:var(--se-purple); color:#fff;
  display:flex; align-items:center; justify-content:center; font-weight:700; }
#chatdock-title .name{ font-weight:600; line-height:1; }
#chatdock-title .sub{ font-size:12px; opacity:.8; line-height:1; }
#chatdock-close{ border:none; background:transparent; color:#fff; padding:4px 8px; border-radius:8px; cursor:pointer; }
#chatdock-close:hover{ background:rgba(255,255,255,.12); }

/* messages */
#chatdock-messages{
  height:430px; overflow-y:auto; padding:12px; background:#f8fafc;
}
#chatdock-messages::-webkit-scrollbar{ width:10px; }
#chatdock-messages::-webkit-scrollbar-thumb{ background:#e5e7eb; border-radius:999px; border:2px solid transparent; }

.se-row{ display:flex; gap:8px; margin:8px 0; }
.se-row.user{ justify-content:flex-end; }
.se-chip{ width:24px; height:24px; border-radius:9999px; background:var(--se-purple); color:#fff; font-size:10px;
  display:grid; place-items:center; margin-top:6px; }

.se-bubble{
  max-width:82%; padding:9px 11px; border-radius:14px; word-wrap:break-word;
  font-size:.92rem; line-height:1.45; box-shadow:0 1px 4px rgba(0,0,0,.08);
}
.se-bot{ background:#fff; border:1px solid var(--se-border); border-bottom-left-radius:6px; }
.se-user{ background:var(--se-purple); color:#fff; border-bottom-right-radius:6px; }
.se-time{ margin-top:4px; font-size:.68rem; color:var(--se-muted); }
.se-time.user{ color:#ffffffcc; }

/* composer */
#chatdock-composer{ border-top:1px solid var(--se-border); padding:12px; background:#fff; }
#chatdock-composer .row{ display:flex; align-items:flex-end; gap:8px; }
#chatdock-input{
  flex:1 1 auto; min-height:40px; max-height:140px; resize:vertical;
  border:1px solid #d1d5db; border-radius:12px; padding:10px 12px;
  background:#fff; color:var(--se-text); font-size:.94rem; line-height:1.35; outline:none;
}
#chatdock-input:focus{ border-color:#c9a1ce; box-shadow:0 0 0 3px rgba(168,0,183,.22); }

#chatdock-send{
  flex:0 0 auto; height:40px; padding:0 14px; border:none; border-radius:12px; cursor:pointer;
  background:var(--se-purple); color:#fff; font-weight:700;
}
#chatdock-send:hover{ filter:brightness(1.05); }
#chatdock-send:active{ filter:brightness(.95); }

/* hide/ignore any backdrop if you left it in markup */
#chatdock-backdrop{ display:none !important; }
</style>

<!-- FAB -->
<button id="chatdock-open" type="button">Chat</button>

<!-- CHAT PANEL -->
<div id="chatdock-panel" role="dialog" aria-modal="true" aria-label="SchedulEase chat">
  <!-- header -->
  <div id="chatdock-header">
    <div id="chatdock-brand">
      <div id="chatdock-avatar">S</div>
      <div id="chatdock-title">
        <div class="name">SchedulEase</div>
        <div class="sub">AI assistant</div>
      </div>
    </div>
    <button id="chatdock-close" type="button" aria-label="Close">✕</button>
  </div>

  <!-- messages -->
  <div id="chatdock-messages">
    <div class="se-row">
      <div class="se-chip">SE</div>
      <div>
        <div class="se-bubble se-bot">
          Hey! I’m your SchedulEase assistant. Ask me about assignments, exams, or to build a study plan.
        </div>
        <div class="se-time" data-time></div>
      </div>
    </div>
  </div>

  <!-- composer -->
  <div id="chatdock-composer">
    <div class="row">
      <textarea id="chatdock-input" placeholder="Type a message…" rows="2"></textarea>
      <button id="chatdock-send" type="button">Send</button>
    </div>
    <div style="font-size:11px; color:#6b7280; margin-top:6px;">
      Enter to send • Shift+Enter for newline
    </div>
  </div>
</div>

<script>
(function(){
  const openBtn = document.getElementById('chatdock-open');
  const closeBtn = document.getElementById('chatdock-close');
  const panel = document.getElementById('chatdock-panel');
  const input = document.getElementById('chatdock-input');
  const sendBtn = document.getElementById('chatdock-send');
  const msgs = document.getElementById('chatdock-messages');

  const fmtTime = () => new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
  const first = msgs.querySelector('[data-time]'); if(first) first.textContent = fmtTime();

  function open(){ panel.style.display='block'; setTimeout(()=>input.focus(), 50); }
  function close(){ panel.style.display='none'; }

  function escapeHtml(s){ return s.replace(/[&<>"']/g, m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m])); }

  function appendUser(text){
    const row = document.createElement('div'); row.className='se-row user';
    row.innerHTML = `<div>
      <div class="se-bubble se-user">${escapeHtml(text)}</div>
      <div class="se-time user">${fmtTime()}</div>
    </div>`;
    msgs.appendChild(row); msgs.scrollTop = msgs.scrollHeight;
  }
  function appendBot(text){
    const row = document.createElement('div'); row.className='se-row';
    row.innerHTML = `<div class="se-chip">SE</div>
      <div>
        <div class="se-bubble se-bot">${escapeHtml(text)}</div>
        <div class="se-time">${fmtTime()}</div>
      </div>`;
    msgs.appendChild(row); msgs.scrollTop = msgs.scrollHeight;
  }
  function send(){
    const val = (input.value||'').trim(); if(!val) return;
    appendUser(val); input.value='';
    setTimeout(()=>appendBot(`Got it! You said: "${val}".\n(Connect me to your backend when ready.)`), 200);
  }
  function onKey(e){ if(e.key==='Enter' && !e.shiftKey){ e.preventDefault(); send(); } }

  openBtn.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  sendBtn.addEventListener('click', send);
  input.addEventListener('keydown', onKey);
})();
</script>
