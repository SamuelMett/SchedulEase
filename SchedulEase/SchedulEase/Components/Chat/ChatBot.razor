@* Chatbot.razor — Modern Blue/Slate Design *@

<style>
:root{
  --se-accent:#2563eb;          /* Primary blue */
  --se-accent-dark:#1d4ed8;
  --se-bg:#f9fafb;
  --se-text:#0f172a;
  --se-muted:#64748b;
  --se-border:#e2e8f0;
  --se-user:#2563eb;
}

/* Floating Chat Button */
#chatdock-open{
  position:fixed; bottom:24px; right:24px; z-index:9999;
  border:none; border-radius:9999px; padding:12px 16px;
  background:linear-gradient(180deg,var(--se-accent),var(--se-accent-dark));
  color:#fff; font-weight:600; cursor:pointer;
  box-shadow:0 10px 28px rgba(37,99,235,.4);
  transition:.2s;
}
#chatdock-open:hover{ transform:translateY(-2px); filter:brightness(1.05); }

/* Panel Layout */
#chatdock-panel{
  position:fixed; bottom:24px; right:24px; z-index:10000;
  width:380px; height:560px;
  display:none; flex-direction:column;
  background:var(--se-bg); color:var(--se-text);
  border:1px solid var(--se-border); border-radius:18px;
  box-shadow:0 12px 40px rgba(0,0,0,.15);
  overflow:hidden;
  font-family:'Inter', 'Segoe UI', sans-serif;
}

/* Header */
#chatdock-header{
  flex:0 0 auto;
  display:flex; align-items:center; justify-content:space-between;
  padding:14px 16px;
  background:linear-gradient(90deg,#1e3a8a,#2563eb);
  color:#fff;
}
#chatdock-brand{ display:flex; align-items:center; gap:10px; }
#chatdock-avatar{
  width:34px; height:34px; border-radius:9999px; background:#fff;
  color:#2563eb; font-weight:700; display:flex; align-items:center; justify-content:center;
  box-shadow:0 0 8px rgba(255,255,255,.3);
}
#chatdock-title .name{ font-weight:600; font-size:15px; line-height:1; }
#chatdock-title .sub{ font-size:12px; opacity:.85; line-height:1; }
#chatdock-close{
  border:none; background:transparent; color:#fff; padding:4px 8px;
  font-size:18px; cursor:pointer; border-radius:8px;
}
#chatdock-close:hover{ background:rgba(255,255,255,.15); }

/* Messages */
#chatdock-messages{
  flex:1 1 auto; min-height:0;
  overflow-y:auto; padding:14px; background:#f1f5f9;
}
#chatdock-messages::-webkit-scrollbar{ width:8px; }
#chatdock-messages::-webkit-scrollbar-thumb{ background:#d1d5db; border-radius:10px; }

.se-row{ display:flex; gap:8px; margin:10px 0; }
.se-row.user{ justify-content:flex-end; }
.se-chip{
  width:26px; height:26px; border-radius:9999px;
  background:var(--se-accent); color:#fff; font-size:11px;
  display:grid; place-items:center; margin-top:4px;
}
.se-bubble{
  max-width:82%; padding:10px 13px; border-radius:16px;
  font-size:.94rem; line-height:1.5;
  box-shadow:0 2px 6px rgba(0,0,0,.06);
}
.se-bot{
  background:#fff; border:1px solid var(--se-border);
  border-bottom-left-radius:6px;
}
.se-user{
  background:var(--se-user); color:#fff;
  border-bottom-right-radius:6px;
}
.se-time{
  margin-top:5px; font-size:.7rem; color:var(--se-muted);
}
.se-time.user{ color:#e0eaff; }

/* Composer */
#chatdock-composer{
  flex:0 0 auto; border-top:1px solid var(--se-border);
  padding:12px; background:#fff;
}
#chatdock-composer .row{
  display:flex; align-items:center; gap:8px;
  background:#f8fafc; border:1px solid #cbd5e1;
  border-radius:14px; padding:6px 8px;
}

/* + button */
#chatdock-plus{
  width:36px; height:36px;
  border:none; border-radius:10px;
  background:#fff; color:#2563eb;
  display:flex; align-items:center; justify-content:center;
  cursor:pointer;
}
#chatdock-plus:hover{ background:#eff6ff; }

/* Input */
#chatdock-input{
  flex:1 1 auto; height:36px;
  border:none; background:transparent; resize:none;
  padding:8px 10px; color:var(--se-text);
  font-size:.94rem; outline:none;
}

/* Send button */
#chatdock-send{
  width:36px; height:36px;
  border:none; border-radius:10px;
  background:var(--se-accent); color:#fff;
  cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  transition:.2s;
}
#chatdock-send:hover{ background:var(--se-accent-dark); transform:translateY(-1px); }

#chatdock-hint{ font-size:11px; color:#94a3b8; margin:6px 4px 0; text-align:center; }
</style>

<button id="chatdock-open" type="button">Chat</button>

<div id="chatdock-panel">
  <div id="chatdock-header">
    <div id="chatdock-brand">
      <div id="chatdock-avatar">S</div>
      <div id="chatdock-title">
        <div class="name">SchedulEase</div>
        <div class="sub">AI assistant</div>
      </div>
    </div>
    <button id="chatdock-close" type="button">✕</button>
  </div>

  <div id="chatdock-messages">
    <div class="se-row">
      <div class="se-chip">SE</div>
      <div>
        <div class="se-bubble se-bot">
          Hey! I’m your SchedulEase assistant. Ask me about assignments, exams, or to build a study plan.
        </div>
        <div class="se-time" data-time></div>
      </div>
    </div>
  </div>

  <div id="chatdock-composer">
    <div class="row">
      <input id="chatdock-file" type="file" multiple style="display:none" />
      <button id="chatdock-plus" type="button" title="Upload files">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>

      <textarea id="chatdock-input" placeholder="Type a message…" rows="1"></textarea>

      <button id="chatdock-send" type="button" title="Send">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <path d="M4 10.5l13.5-6.5-6.5 13.5-1-5.5-6-1.5z" stroke="currentColor" stroke-width="2" fill="currentColor"/>
        </svg>
      </button>
    </div>
    <div id="chatdock-hint">Enter to send • Shift+Enter for newline</div>
  </div>
</div>

<script>
(function(){
  const openBtn = document.getElementById('chatdock-open');
  const closeBtn = document.getElementById('chatdock-close');
  const panel = document.getElementById('chatdock-panel');
  const input = document.getElementById('chatdock-input');
  const sendBtn = document.getElementById('chatdock-send');
  const msgs = document.getElementById('chatdock-messages');
  const fileBtn = document.getElementById('chatdock-plus');
  const fileInput = document.getElementById('chatdock-file');

  const fmtTime = () => new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
  const first = msgs.querySelector('[data-time]'); if(first) first.textContent = fmtTime();

  const open = () => { panel.style.display='flex'; setTimeout(()=>input.focus(), 30); };
  const close = () => panel.style.display='none';
  const escapeHtml = s => s.replace(/[&<>"']/g, m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));

  const appendUser = text => {
    const row = document.createElement('div'); row.className='se-row user';
    row.innerHTML = `<div><div class="se-bubble se-user">${escapeHtml(text)}</div><div class="se-time user">${fmtTime()}</div></div>`;
    msgs.appendChild(row); msgs.scrollTop = msgs.scrollHeight;
  };

  const appendBot = text => {
    const row = document.createElement('div'); row.className='se-row';
    row.innerHTML = `<div class="se-chip">SE</div><div><div class="se-bubble se-bot">${escapeHtml(text)}</div><div class="se-time">${fmtTime()}</div></div>`;
    msgs.appendChild(row); msgs.scrollTop = msgs.scrollHeight;
  };

  function dummyReply(txt){
    const t = txt.toLowerCase();
    if(t.includes("schedule") || t.includes("plan"))
      return "Here’s a sample plan for your day:\n- 8:00 AM — CS Lecture\n- 11:00 AM — Project Work\n- 2:00 PM — Lunch\n- 3:00 PM — Study Hour ";
    if(t.includes("assignment") || t.includes("homework"))
      return "You currently have 3 assignments pending:\n• AI Lab 4 (due Oct 20)\n• UX Report (due Oct 22)\n• DBMS Project (due Oct 25)";
    if(t.includes("exam") || t.includes("test"))
      return "Next exam: CMPS 383 — Software Eng. on Tuesday 9:00AM ";
    if(t.includes("hello") || t.includes("hi"))
      return "Hey there  How can I help today?";
    if(t.includes("thanks") || t.includes("thank"))
      return "No problem! Happy to help ";
    return "Hmm, I didn’t catch that — try asking about your schedule, exams, or assignments.";
  }

  const send = () => {
    const val = (input.value||'').trim(); if(!val) return;
    appendUser(val); input.value='';
    const reply = dummyReply(val);
    setTimeout(()=>appendBot(reply), 350);
  };

  const formatBytes = n => {
    if (!n && n !== 0) return '';
    const u = ['B','KB','MB','GB','TB']; let i=0;
    while(n>=1024 && i<u.length-1){ n/=1024; i++; }
    return `${n.toFixed(n<10&&i>0?1:0)} ${u[i]}`;
  };

  openBtn.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  sendBtn.addEventListener('click', send);
  input.addEventListener('keydown', e => { if(e.key==='Enter' && !e.shiftKey){ e.preventDefault(); send(); } });
  fileBtn.addEventListener('click', ()=> fileInput.click());
  fileInput.addEventListener('change', ()=>{
    const files = Array.from(fileInput.files||[]);
    if(!files.length) return;
    const summary = files.map(f=>`${f.name} (${formatBytes(f.size)})`).join('\\n');
    appendBot(`Files selected:\\n${escapeHtml(summary)}\\n(Handle upload in backend.)`);
    fileInput.value='';
  });
})();
</script>
