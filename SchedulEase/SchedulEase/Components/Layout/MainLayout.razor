@inherits LayoutComponentBase
@using SchedulEase.Components.Layout
@using SchedulEase.Components.Chat

<div class="min-h-screen bg-background text-foreground">

    <header class="border-b border-border bg-card">
        <div class="container mx-auto px-4 py-4 flex justify-between items-center">
            <a href="/" class="flex items-center gap-3">
                <Icon Name="Calendar" Class="w-6 h-6 text-primary" />
                <h1 class="text-xl font-bold">
                    Schedul<span class="text-red-600">Ease</span>
                </h1>
            </a>

            <nav class="flex gap-4 text-sm font-medium text-muted-foreground">
                <NavLink href="/" Match="NavLinkMatch.All" class="hover:text-primary transition-colors">Home</NavLink>
                <NavLink href="/canvas" class="hover:text-primary transition-colors">Canvas</NavLink>
                <NavLink href="/upload" class="hover:text-primary transition-colors">Upload</NavLink>
                <NavLink href="/calendar" class="hover:text-primary transition-colors">Calendar</NavLink>
                <NavLink href="/chat" class="hover:text-primary transition-colors">AI Chat</NavLink>
                <NavLink href="/settings" class="hover:text-primary transition-colors">Settings</NavLink>
            </nav>
        </div>
    </header>

    <main class="container mx-auto px-4 py-6">
        @Body
    </main>
</div>
