// Components/Icon.razor
<span class="@Class">
    @switch (Name)
    {
        case "Calendar":
            <Icons.Calendar />
            break;
        case "FileText":
            <Icons.FileText />
            break;
        // Add cases for all other icons...
    }
</span>

@code {
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public string? Class { get; set; }
}

